<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFBFE">

    <!-- Modern Top Bar (Material Design 3) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#6750A4"
        android:gravity="center_vertical"
        android:elevation="4dp"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <!-- Menu Button -->
        <ImageView
            android:id="@+id/btnSessionMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_menu"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="메뉴"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Title -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Health Chat"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSessionSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Claude AI 건강 어시스턴트"
                android:textSize="11sp"
                android:textColor="#D0BCFF" />
        </LinearLayout>

        <!-- Health Data Button -->
        <TextView
            android:id="@+id/btnHealthMenu"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="건강데이터 ▾"
            android:textSize="12sp"
            android:textColor="#6750A4"
            android:background="@drawable/health_menu_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <!-- Category Chips (hidden by default) -->
    <HorizontalScrollView
        android:id="@+id/healthCategoryScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/healthCategoryContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Chat Messages -->
        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true"
            android:background="#FFFBFE"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </ScrollView>

        <!-- Sessions Panel (Right Drawer) -->
        <LinearLayout
            android:id="@+id/sessionsPanelContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0"
            android:orientation="vertical"
            android:background="#FFFBFE"
            android:visibility="gone"
            android:elevation="8dp">

            <!-- Panel Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#6750A4"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="대화 목록"
                    android:textSize="17sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnClosePanel"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_close"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:contentDescription="닫기"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <!-- New Chat Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <Button
                    android:id="@+id/btnNewSession"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="+ 새 채팅"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E7E0EC" />

            <!-- Sessions List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/sessionsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </LinearLayout>

    <!-- Modern Input Area (Material Design 3) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/input_area_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <!-- Camera Button -->
        <ImageView
            android:id="@+id/btnCamera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/fab_camera_bg"
            android:src="@drawable/ic_camera"
            android:padding="10dp"
            android:contentDescription="카메라"
            android:layout_marginEnd="8dp"
            android:scaleType="centerInside" />

        <!-- Debug Button -->
        <ImageView
            android:id="@+id/btnDebug"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/debug_button_bg"
            android:src="@drawable/ic_debug"
            android:padding="9dp"
            android:contentDescription="디버그"
            android:layout_marginEnd="8dp"
            android:scaleType="centerInside" />

        <!-- Message Input -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:hint="건강에 대해 물어보세요..."
            android:background="@drawable/edit_text_modern_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:textColor="#1C1B1F"
            android:textColorHint="#9E9EA6"
            android:maxLines="1"
            android:inputType="text"
            android:layout_marginEnd="8dp"
            android:elevation="0dp" />

        <!-- Send Button -->
        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/send_button_modern_bg"
            android:src="@drawable/ic_send"
            android:padding="10dp"
            android:contentDescription="전송"
            android:scaleType="centerInside" />
    </LinearLayout>

</LinearLayout>
