<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#FF6F0F"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnSessionMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_menu"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:visibility="gone"
            android:contentDescription="세션메뉴"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="4dp">

            <TextView
                android:id="@+id/tvTopBarDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvTopBarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Health Chat"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvSessionSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFD0A0"
                android:textSize="12sp"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvHealthScoreBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--점"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/daangn_orange_btn_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <ImageView
            android:id="@+id/btnBell"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_bell"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="알림"/>

        <TextView
            android:id="@+id/btnHealthMenu"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="건강데이터 ▾"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/health_menu_bg"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- CONTENT -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- HOME TAB -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/tabHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F8F8F8"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 실시간 심박수 카드 -->
                <LinearLayout
                    android:id="@+id/cardLiveHeartRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/daangn_card_bg"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:elevation="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvHeartBeatIcon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="♥"
                                android:textColor="#F44336"
                                android:textSize="18sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="  실시간 심박수"
                                android:textColor="#888888"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/tvLiveHeartRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#F44336"
                                android:textSize="44sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" bpm"
                                android:textColor="#AAAAAA"
                                android:textSize="14sp"
                                android:layout_marginBottom="8dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvHeartRateStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="측정 대기..."
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tvHeartRateTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#BBBBBB"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/btnToggleHrMonitor"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="시작"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:background="@drawable/daangn_orange_btn_bg"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"/>

                        <TextView
                            android:id="@+id/tvHrPollLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15초 갱신"
                            android:textColor="#BBBBBB"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"
                            android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Health Score Card -->
                <LinearLayout
                    android:id="@+id/cardHealthScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/daangn_health_score_bg"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="오늘의 건강점수"
                            android:textColor="#888888"
                            android:textSize="13sp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/tvHealthScoreValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FF6F0F"
                                android:textSize="48sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="/100"
                                android:textColor="#AAAAAA"
                                android:textSize="14sp"
                                android:layout_marginStart="4dp"
                                android:layout_marginBottom="8dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvHealthScoreGrade"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="데이터 로딩중..."
                            android:textColor="#666666"
                            android:textSize="12sp"/>

                        <ProgressBar
                            android:id="@+id/pbHealthScore"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="8dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FF6F0F"
                            android:progressBackgroundTint="#FFDDCC"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="수면"
                            android:textColor="#888888"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvSleepScoreSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#1C1B1F"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <View
                            android:layout_width="40dp"
                            android:layout_height="1dp"
                            android:background="#DDDDDD"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="스트레스"
                            android:textColor="#888888"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvStressLevelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#1C1B1F"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘의 건강"
                    android:textColor="#1C1B1F"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="20dp"
                    android:layout_marginStart="-16dp"
                    android:layout_marginEnd="-16dp">

                    <LinearLayout
                        android:id="@+id/metricsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="4dp"/>
                </HorizontalScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="수면"
                    android:textColor="#1C1B1F"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/cardSleep"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/daangn_card_bg"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:elevation="1dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_sleep"
                        android:scaleType="centerInside"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/tvSleepSummary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="데이터 로딩중..."
                        android:textColor="#1C1B1F"
                        android:textSize="14sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘 영양"
                    android:textColor="#1C1B1F"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/cardNutrition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/daangn_card_bg"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="1dp">

                    <TextView
                        android:id="@+id/tvNutritionSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="식사 기록이 없습니다"
                        android:textColor="#666666"
                        android:textSize="14sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="최근 운동"
                    android:textColor="#1C1B1F"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/cardExercise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/daangn_card_bg"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="1dp">

                    <TextView
                        android:id="@+id/tvExerciseSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="운동 기록이 없습니다"
                        android:textColor="#666666"
                        android:textSize="14sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="16dp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- CHAT TAB -->
        <LinearLayout
            android:id="@+id/tabChat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <HorizontalScrollView
                android:id="@+id/healthCategoryScroll"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:scrollbars="none"
                android:background="#F8F8F8"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/healthCategoryContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:gravity="center_vertical"/>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <ScrollView
                    android:id="@+id/scrollView"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fillViewport="true"
                    android:background="#FFFBFE">

                    <LinearLayout
                        android:id="@+id/chatContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="8dp"/>
                </ScrollView>

                <LinearLayout
                    android:id="@+id/sessionsPanelContainer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="#FFFBFE"
                    android:elevation="8dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:background="#FF6F0F"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="대화 목록"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <ImageView
                            android:id="@+id/btnClosePanel"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_close"
                            android:scaleType="centerInside"
                            android:padding="8dp"
                            android:contentDescription="닫기"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnNewSession"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="+ 새 채팅"
                        android:layout_margin="12dp"
                        android:backgroundTint="#FF6F0F"
                        android:textColor="#FFFFFF"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/sessionsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Input Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/input_area_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical"
                android:elevation="8dp">

                <ImageView
                    android:id="@+id/btnCamera"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_camera"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:background="@drawable/daangn_orange_btn_bg"
                    android:contentDescription="카메라"
                    android:layout_marginEnd="6dp"/>

                <ImageView
                    android:id="@+id/btnDebug"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_debug"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:background="@drawable/debug_button_bg"
                    android:contentDescription="디버그"
                    android:layout_marginEnd="6dp"/>

                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:hint="건강에 대해 물어보세요..."
                    android:textColor="#1C1B1F"
                    android:textSize="14sp"
                    android:background="@drawable/edit_text_modern_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:imeOptions="actionSend"
                    android:inputType="textMultiLine"
                    android:maxLines="3"
                    android:layout_marginEnd="6dp"/>

                <ImageView
                    android:id="@+id/btnSend"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_send"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:background="@drawable/daangn_orange_btn_bg"
                    android:contentDescription="전송"/>
            </LinearLayout>
        </LinearLayout>

        <!-- RECORDS TAB -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/tabRecords"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F8F8F8"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/recordsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"/>
        </androidx.core.widget.NestedScrollView>

        <!-- PROFILE TAB -->
        <ScrollView
            android:id="@+id/tabProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F8F8F8"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/profileContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"/>
        </ScrollView>

    </FrameLayout>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:background="@drawable/daangn_bottom_nav_bg"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/btnTabHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:scaleType="centerInside"/>

            <TextView
                android:id="@+id/navHomeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="홈"
                android:textSize="10sp"
                android:textColor="#FF6F0F"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <ImageView
                android:id="@+id/navChatIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat_bubble"
                android:scaleType="centerInside"/>

            <TextView
                android:id="@+id/navChatLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="채팅"
                android:textSize="10sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabRecords"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <ImageView
                android:id="@+id/navRecordsIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chart_bar"
                android:scaleType="centerInside"/>

            <TextView
                android:id="@+id/navRecordsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기록"
                android:textSize="10sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <ImageView
                android:id="@+id/navProfileIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_person"
                android:scaleType="centerInside"/>

            <TextView
                android:id="@+id/navProfileLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="나"
                android:textSize="10sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
