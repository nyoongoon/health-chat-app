<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFBFE">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#6750A4"
        android:elevation="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <!-- Row: [☰] [Title+Subtitle] [건강데이터] -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnSessionMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="☰"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Health Chat"
                    android:textSize="19sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSessionSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Claude AI 건강 어시스턴트"
                    android:textSize="11sp"
                    android:textColor="#D0BCFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnHealthMenu"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="건강데이터 ▾"
                android:textSize="12sp"
                android:textColor="#6750A4"
                android:background="@drawable/health_menu_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />
        </LinearLayout>

        <!-- Category chips (hidden by default) -->
        <HorizontalScrollView
            android:id="@+id/healthCategoryScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:scrollbars="none"
            android:paddingStart="8dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/healthCategoryContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

    </LinearLayout>

    <!-- Main content area: Chat + Sessions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Chat Messages -->
        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true"
            android:background="#FFFBFE">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </ScrollView>

        <!-- Sessions panel (collapsed to 0 width initially) -->
        <LinearLayout
            android:id="@+id/sessionsPanelContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0"
            android:orientation="vertical"
            android:background="#FFFBFE"
            android:visibility="gone">

            <!-- Panel Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#6750A4"
                android:paddingStart="18dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="대화 목록"
                    android:textSize="17sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnClosePanel"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="✕"
                    android:textSize="18sp"
                    android:textColor="#EADDFF"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <!-- New Chat Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <Button
                    android:id="@+id/btnNewSession"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="+ 새 채팅"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E7E0EC" />

            <!-- Sessions List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/sessionsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </LinearLayout>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F3EEF8"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/btnCamera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/camera_button_bg"
            android:src="@drawable/ic_camera"
            android:padding="12dp"
            android:contentDescription="사진"
            android:layout_marginEnd="8dp"
            android:elevation="2dp" />

        <ImageView
            android:id="@+id/btnDebug"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/debug_button_bg"
            android:src="@drawable/ic_debug"
            android:padding="10dp"
            android:contentDescription="디버그"
            android:layout_marginEnd="8dp"
            android:elevation="2dp" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="건강에 대해 물어보세요..."
            android:background="@drawable/edit_text_bg"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textSize="15sp"
            android:textColor="#1C1B1F"
            android:textColorHint="#9E9EA6"
            android:maxLines="4"
            android:inputType="textMultiLine"
            android:layout_marginEnd="10dp" />

        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/send_button_bg"
            android:src="@drawable/ic_send"
            android:padding="13dp"
            android:contentDescription="전송"
            android:elevation="2dp" />

    </LinearLayout>

</LinearLayout>
